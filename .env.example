# NASA Sky Tracker — Environment Variables
# Copy to `.env` and fill in real values. Never commit real secrets.

# --- Database (Postgres 17 via docker-compose) ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme
POSTGRES_DB=nasa_sky_tracker

# --- NASA API ---
# Get a key at https://api.nasa.gov/; falls back to DEMO_KEY if unset
NASA_API_KEY=DEMO_KEY

# --- Auth / JWT ---
# Required in production; a random dev fallback is used if unset
JWT_SECRET=

# --- Discord (optional; default sends mocked log rows only) ---
# When DISABLE_NOTIFICATION_MOCK=true the API will POST to each subscriber's
# discordWebhookUrl. Webhook URLs are stored in subscribers (masked on read).
DISABLE_NOTIFICATION_MOCK=false

# --- APOD scheduler ---
APOD_CRON=0 16 * * *
APOD_BACKOFF_MS=1000,3000,9000
APOD_BOOT_CATCHUP=true
APOD_TIMEOUT_MS=15000

# --- EONET scheduler ---
EONET_POLL_MINUTES=15
EONET_CLOSED_WINDOW_DAYS=30
EONET_BACKOFF_MS=1000,3000,9000
EONET_BOOT_CATCHUP=true
EONET_TIMEOUT_MS=30000

# --- Auth-toggle (architecture §4 / §7) ---
# When false, all routes are public (default in dev); when true, reads are still
# public via @Public() opt-in, writes require a JWT.
AUTH_REQUIRED=false
