# NASA Sky Tracker — Environment Variables
# Copy to `.env` and fill in real values. Never commit real secrets.
#
# Every variable listed here maps to a real `process.env` read in `src/`.
# `APOD_BACKOFF_MS` / `EONET_BACKOFF_MS` are intentionally NOT listed — they
# are Nest injection tokens with hardcoded defaults `[1000,3000,9000]` and are
# never read from the environment.

# --- Runtime ---
# NestJS listen port (default 3000).
PORT=3000
# One of development | production | test. Production enforces fail-fast env
# validation (JWT_SECRET + POSTGRES_* required; numeric/enum vars constrained).
NODE_ENV=development

# --- Database (Postgres 17 via docker-compose) ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=********
POSTGRES_DB=nasa_sky_tracker

# --- NASA API ---
# Get a key at https://api.nasa.gov/; falls back to DEMO_KEY if unset.
NASA_API_KEY=DEMO_KEY
# Optional overrides (defaults point at the real NASA endpoints; mainly for tests).
APOD_BASE_URL=https://api.nasa.gov/planetary/apod
EONET_BASE_URL=https://eonet.gsfc.nasa.gov/api/v3

# --- Auth / JWT ---
# Required in production; a random dev fallback is used if unset outside prod.
JWT_SECRET=change-me-in-prod
# JWT lifetime (default 7d).
JWT_EXPIRES_IN=7d
# When false, all routes are public (default in dev); when true, reads are
# still public via @Public() opt-in, writes require a JWT.
AUTH_REQUIRED=false

# --- Discord transport (optional; default sends mocked log rows only) ---
# When DISABLE_NOTIFICATION_MOCK=true the API POSTs to each subscriber's
# discordWebhookUrl. Webhook URLs are stored in subscribers (masked on read).
DISABLE_NOTIFICATION_MOCK=false

# --- APOD scheduler ---
APOD_CRON=0 16 * * *
APOD_BOOT_CATCHUP=true
APOD_TIMEOUT_MS=15000

# --- EONET scheduler ---
EONET_POLL_MINUTES=15
EONET_CLOSED_WINDOW_DAYS=30
EONET_BOOT_CATCHUP=true
EONET_TIMEOUT_MS=30000
