# NASA Sky Tracker — environment template
# Copy to `.env` and fill in real values. Never commit real secrets.

# --- Runtime ---
PORT=3000
NODE_ENV=development

# --- Database (Postgres) ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me
POSTGRES_DB=nasa_sky_tracker

# --- NASA API (get a key at https://api.nasa.gov/; DEMO_KEY is rate-limited) ---
NASA_API_KEY=DEMO_KEY

# --- Auth / JWT ---
JWT_SECRET=change-me-in-prod
JWT_EXPIRES_IN=7d
AUTH_REQUIRED=false

# --- Discord notifications (optional; true = send to real webhooks) ---
DISABLE_NOTIFICATION_MOCK=false
