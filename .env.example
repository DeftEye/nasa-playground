# NASA Sky Tracker — Environment Variables
# Copy to `.env` and fill in real values. Never commit real secrets.

# --- Database (Postgres 17 via docker-compose) ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme
POSTGRES_DB=nasa_sky_tracker
# Full connection URL (optional; derived from POSTGRES_* above if omitted)

# --- NASA API ---
# Get a key at https://api.nasa.gov/; falls back to DEMO_KEY if unset
NASA_API_KEY=DEMO_KEY

# --- Auth / JWT ---
# Required in production; a random dev fallback is used if unset
JWT_SECRET=
# Token TTL (default 7d)
JWT_EXPIRES_IN=7d

# --- Schedulers ---
# APOD cron expression (default: 4 PM UTC daily)
APOD_CRON=0 16 * * *
# EONET poll interval in minutes (default 15)
EONET_POLL_MINUTES=15
# EONET closed-event lookback window in days (default 30; bounded so closed-fetch is never unbounded)
EONET_CLOSED_WINDOW_DAYS=30

# --- Notifications / Discord ---
# Optional fallback webhook URL for subscribers without their own
DISCORD_DEFAULT_WEBHOOK_URL=
# Set to true to send real Discord POSTs (default: mock mode writes notification_log with status='mocked')
DISABLE_NOTIFICATION_MOCK=false

# --- App ---
# NestJS listen port (default 3000)
PORT=3000
# When false, public NASA read endpoints skip JWT (default true)
AUTH_REQUIRED=true
